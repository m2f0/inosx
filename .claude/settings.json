{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git config --local --get:*)",
      "Bash(git config --local --list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npm run validate-i18n:*)",
      "Bash(npm run audit-i18n:*)",
      "Bash(npm test:*)",
      "Bash(node:*)",
      "Bash(npx --yes impeccable:*)",
      "Bash(npx impeccable:*)",
      "Bash(python -m http.server:*)",
      "Bash(python -m json.tool:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(curl -I:*)",
      "Bash(curl -s:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "WebFetch(domain:inosx.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:validator.schema.org)",
      "WebFetch(domain:opengraph.xyz)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(rm -rf:*)",
      "Bash(vercel --prod:*)",
      "Bash(vercel deploy --prod:*)",
      "Bash(supabase db reset:*)",
      "Bash(supabase db push:*)",
      "Bash(npm publish:*)",
      "Bash(npm install -g:*)",
      "Bash(npm i -g:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Antes de salvar este arquivo, verifique se o conteúdo a ser gravado contém a string literal `mario@inosx.com`. Se contiver E o arquivo NÃO for `CLAUDE.local.md`, `.git/config`, `CHANGELOG.claude.md`, ou outro caminho explicitamente gitignored, BLOQUEIE a operação e explique que o email pessoal do Mario não pode entrar em arquivos versionados.\n\nSe o arquivo for um dos gitignored permitidos, ou se a string não aparece, deixe seguir."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Se o arquivo recém-editado tem caminho que casa com `i18n/*.json` (en.json, pt.json, es.json), execute `npm run validate-i18n` via Bash e reporte resultado breve (OK ou os erros). Caso contrário, não faça nada."
          }
        ]
      }
    ]
  }
}
